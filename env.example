# 貓步漫遊 環境變數
# 複製這個檔案為 .env，填入真實的 key

# Notion Integration Token
# 建立方式：https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion Reports Database ID
# 開啟 Reports database → 複製網址裡的32字元 ID
NOTION_REPORTS_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini API Key
# 取得方式：https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
