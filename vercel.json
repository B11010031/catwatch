{
  "rewrites": [
    {
      "source": "/public/:path*",
      "destination": "/public/:path*"
    },
    {
      "source": "/((?!public/).*)",
      "destination": "/site.html"
    }
  ],
  "headers": [
    {
      "source": "/public/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
